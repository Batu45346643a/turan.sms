# Turan SMS - Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun

# ============================================
# TWILIO SMS AYARLARI
# ============================================
# Twilio hesabından alınabilir: https://www.twilio.com/console

# Twilio Account SID
TWILIO_ACCOUNT_SID=your_account_sid_here

# Twilio Auth Token
TWILIO_AUTH_TOKEN=your_auth_token_here

# Twilio telefon numarası (SMS göndereceği numara)
# Format: +90XXXXXXXXXX (Türkiye için)
TWILIO_PHONE_NUMBER=+90XXXXXXXXXX

# ============================================
# UYGULAMA AYARLARI
# ============================================

# Uygulamanın çalıştığı ortam (development, production)
ENVIRONMENT=development

# Veri dosyalarının konumu
DATA_DIR=data

# ============================================
# KONUM AYARLARI
# ============================================

# Google Maps API Key (konumla ilgili özellikler için - isteğe bağlı)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ============================================
# ACİL DURUM AYARLARI
# ============================================

# Varsayılan acil durum kişileri (virgülle ayrılmış)
# EMERGENCY_CONTACTS=+90XXXXXXXXXX,+90YYYYYYYYY

# ============================================
# MESH NETWORK AYARLARI
# ============================================

# Bu cihazın Mesh ağındaki ID'si
MESH_NODE_ID=node_default

# Bu cihazın Mesh ağındaki adı
MESH_NODE_NAME=Turan Device

# Mesh portları
MESH_PORT=5000
